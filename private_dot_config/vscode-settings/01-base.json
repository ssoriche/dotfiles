{
  "editor.lineNumbers": "relative",
  "editor.cursorSurroundingLines": 8,
  "editor.scrolloff": 8,
  "editor.wrap": false,
  "editor.minimap.enabled": false,
  "editor.renderWhitespace": "none",
  "editor.renderControlCharacters": false,
  "editor.fontFamily": "JetBrains Mono, Menlo, Monaco, 'Courier New', monospace",
  "editor.fontSize": 14,
  "editor.lineHeight": 1.5,
  "editor.tabSize": 2,
  "editor.insertSpaces": true,
  "editor.detectIndentation": true,
  "editor.formatOnSave": false,
  "editor.codeActionsOnSave": {
    "source.organizeImports": "explicit"
  },
  "files.trimTrailingWhitespace": true,
  "files.insertFinalNewline": true,
  "files.trimFinalNewlines": true,
  "files.autoSave": "onFocusChange",
  "workbench.startupEditor": "none",
  "workbench.editor.enablePreview": false,
  "workbench.activityBar.visible": false,
  "workbench.statusBar.visible": true,
  "workbench.editor.showTabs": "multiple",
  "workbench.editor.tabCloseButton": "right",
  "explorer.compactFolders": false,
  "explorer.confirmDelete": false,
  "explorer.confirmDragAndDrop": false,
  "workbench.tree.indent": 20,
  "search.useGlobalIgnoreFiles": true,
  "search.exclude": {
    "**/node_modules": true,
    "**/dist": true,
    "**/build": true,
    "**/target": true,
    "**/.git": true,
    "**/.svn": true,
    "**/.hg": true,
    "**/CVS": true,
    "**/.DS_Store": true,
    "**/Thumbs.db": true
  },
  "files.exclude": {
    "**/.git": true,
    "**/.svn": true,
    "**/.hg": true,
    "**/CVS": true,
    "**/.DS_Store": true,
    "**/Thumbs.db": true
  },
  "terminal.integrated.scrollback": 10000,
  "terminal.integrated.copyOnSelection": true,
  "window.zoomLevel": 0,
  "breadcrumbs.enabled": true,
  "editor.suggest.insertMode": "replace",
  "editor.acceptSuggestionOnCommitCharacter": false,
  "security.workspace.trust.enabled": true,
  "security.workspace.trust.untrustedFiles": "open",
  "security.workspace.trust.startupPrompt": "never",
  "security.workspace.trust.emptyWindow": true,
  "security.workspace.trust.directories": [
    "/Users/shawns/.local/share/chezmoi",
    "/Volumes/ziprecruiter/zr"
  ],
  "workbench.editor.untitled.hint": "hidden",
  "window.closeWhenEmpty": false,
  "window.restoreWindows": "all",
  "git.enableSmartCommit": false,
  "git.inputValidation": "always",
  "git.inputValidationSubjectLength": 72,
  "git.inputValidationLength": 72,
  "git.postCommitCommand": "none",
  "git.confirmSync": true,
  "git.requireGitUserConfig": true,
  "git.showActionButton": {
    "commit": true,
    "publish": false,
    "sync": false
  },
  "[git-commit]": {
    "editor.rulers": [50, 72],
    "editor.wordWrap": "off",
    "editor.fontFamily": "JetBrains Mono, Menlo, Monaco, 'Courier New', monospace",
    "editor.fontSize": 13,
    "editor.quickSuggestions": {
      "comments": false,
      "strings": true,
      "other": false
    }
  },
  "git.inputValidationSubjectRegex": "^(feat|fix|docs|style|refactor|perf|test|build|ci|chore|revert)(\\([a-z0-9-]+\\))?: [a-z].*$",
  "git.inputValidationErrorMessage": "Commit message must follow conventional commit format: <type>(<scope>): <description>",
  "scm.inputFontSize": 13,
  "scm.showInputActionButton": false,
  "scm.defaultViewMode": "tree",
  "scm.showIncomingChanges": "never",
  "scm.showOutgoingChanges": "never",
  "scm.alwaysShowActions": false,
  "scm.alwaysShowRepositories": false,
  "github-actions.workflows.pinned.workflows": [],
  "github-actions.workflows.pinned.refresh.enabled": true,
  "github-actions.workflows.pinned.refresh.interval": 65,
  "github-actions.remote-name": "origin",
  "github-actions.step-debug-enabled": true,
  "github-actions.step-security.enabled": true,
  "github-actions.workflows.validate.enabled": true,
  "github-actions.workflows.validate.onSave": true,
  "github-actions.workflows.validate.schema": true,
  "github-actions.workflows.icons.enabled": true,
  "editor.lightbulb.enabled": false,
  "workbench.statusBar.height": 24,
  "workbench.statusBar.reduceMotion": true,
  "workbench.statusBar.noFolderText": "",
  "workbench.statusBar.focusBorder": false,
  "workbench.statusBar.foreground": "#a6adc8",
  "workbench.statusBar.background": "#1e1e2e",
  "workbench.statusBar.border": false,
  "workbench.statusBar.separators": {
    "separator": " ",
    "sectionSeparator": " "
  },
  "workbench.statusBar.items": {
    "mode": {
      "name": "mode",
      "text": "$(vim) $(mode)",
      "alignment": "left",
      "priority": 100
    },
    "git": {
      "name": "git",
      "text": "$(git-branch) $(branch)",
      "alignment": "left",
      "priority": 90
    },
    "filetype": {
      "name": "filetype",
      "text": "$(file) $(filetype)",
      "alignment": "right",
      "priority": 80
    },
    "encoding": {
      "name": "encoding",
      "text": "$(encoding)",
      "alignment": "right",
      "priority": 70
    },
    "position": {
      "name": "position",
      "text": "$(position)",
      "alignment": "right",
      "priority": 60
    }
  }
}
