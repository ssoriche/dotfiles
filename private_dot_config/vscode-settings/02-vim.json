{
  "vim.leader": "<space>",
  "vim.useSystemClipboard": true,
  "vim.easymotion": true,
  "vim.incsearch": true,
  "vim.useCtrlKeys": true,
  "vim.hlsearch": true,
  "vim.smartRelativeLine": true,
  "vim.whichkey.enabled": true,
  "vim.whichkey.delay": 0,
  "vim.whichkey.showMenu": "onlyMenu",
  "vim.handleKeys": {
    "<C-a>": false,
    "<C-f>": false,
    "<C-c>": false,
    "<C-v>": false,
    "<C-x>": false,
    "<C-z>": false
  },
  "vim.insertModeKeyBindings": [
    {
      "before": ["j", "k"],
      "after": ["<Esc>"]
    }
  ],
  "vim.normalModeKeyBindingsNonRecursive": [
    {
      "before": ["<leader>", "f"],
      "name": "+file"
    },
    {
      "before": ["<leader>", "f", "f"],
      "commands": ["workbench.action.quickOpen"],
      "name": "Find File"
    },
    {
      "before": ["<leader>", "f", "r"],
      "commands": ["workbench.action.openRecent"],
      "name": "Recent Files"
    },
    {
      "before": ["<leader>", "f", "g"],
      "commands": ["workbench.action.findInFiles"],
      "name": "Find in Files"
    },
    {
      "before": ["<leader>", "f", "s"],
      "commands": ["workbench.action.files.save"],
      "name": "Save File"
    },
    {
      "before": ["<leader>", "f", "S"],
      "commands": ["workbench.action.files.saveAll"],
      "name": "Save All Files"
    },
    {
      "before": ["<leader>", "b"],
      "name": "+buffer"
    },
    {
      "before": ["<leader>", "b", "b"],
      "commands": ["workbench.action.showAllEditors"],
      "name": "Show All Buffers"
    },
    {
      "before": ["<leader>", "b", "d"],
      "commands": ["workbench.action.closeActiveEditor"],
      "name": "Delete Buffer"
    },
    {
      "before": ["<leader>", "b", "n"],
      "commands": ["workbench.action.nextEditor"],
      "name": "Next Buffer"
    },
    {
      "before": ["<leader>", "b", "p"],
      "commands": ["workbench.action.previousEditor"],
      "name": "Previous Buffer"
    },
    {
      "before": ["<leader>", "e"],
      "commands": ["workbench.view.explorer"],
      "name": "Explorer"
    },
    {
      "before": ["<leader>", "t"],
      "commands": ["workbench.action.terminal.toggleTerminal"],
      "name": "Toggle Terminal"
    },
    {
      "before": ["<leader>", "g"],
      "name": "+git"
    },
    {
      "before": ["<leader>", "g", "g"],
      "commands": ["workbench.view.scm"],
      "name": "Source Control"
    },
    {
      "before": ["<leader>", "g", "s"],
      "commands": ["git.stage"],
      "name": "Stage Changes"
    },
    {
      "before": ["<leader>", "g", "u"],
      "commands": ["git.unstage"],
      "name": "Unstage Changes"
    },
    {
      "before": ["<leader>", "c"],
      "name": "+code"
    },
    {
      "before": ["<leader>", "c", "a"],
      "commands": ["editor.action.quickFix"],
      "name": "Quick Fix"
    },
    {
      "before": ["<leader>", "c", "r"],
      "commands": ["editor.action.rename"],
      "name": "Rename Symbol"
    },
    {
      "before": ["<leader>", "c", "f"],
      "commands": ["editor.action.formatDocument"],
      "name": "Format Document"
    },
    {
      "before": ["<leader>", "c", "d"],
      "commands": ["editor.action.revealDefinition"],
      "name": "Go to Definition"
    },
    {
      "before": ["<leader>", "c", "i"],
      "commands": ["editor.action.goToImplementation"],
      "name": "Go to Implementation"
    },
    {
      "before": ["<leader>", "w"],
      "name": "+window"
    },
    {
      "before": ["<leader>", "w", "h"],
      "commands": ["workbench.action.focusLeftGroup"],
      "name": "Focus Left"
    },
    {
      "before": ["<leader>", "w", "l"],
      "commands": ["workbench.action.focusRightGroup"],
      "name": "Focus Right"
    },
    {
      "before": ["<leader>", "w", "j"],
      "commands": ["workbench.action.focusBelowGroup"],
      "name": "Focus Down"
    },
    {
      "before": ["<leader>", "w", "k"],
      "commands": ["workbench.action.focusAboveGroup"],
      "name": "Focus Up"
    },
    {
      "before": ["<leader>", "w", "v"],
      "commands": ["workbench.action.splitEditor"],
      "name": "Split Vertical"
    },
    {
      "before": ["<leader>", "w", "s"],
      "commands": ["workbench.action.splitEditorDown"],
      "name": "Split Horizontal"
    },
    {
      "before": ["<leader>", "w", "d"],
      "commands": ["workbench.action.closeEditorsInGroup"],
      "name": "Close Window"
    }
  ],
  "vim.visualModeKeyBindingsNonRecursive": [
    {
      "before": ["<leader>", "c", "f"],
      "commands": ["editor.action.formatSelection"],
      "name": "Format Selection"
    }
  ]
}
