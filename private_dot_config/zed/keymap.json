[
  // === VIM MODE KEYBINDINGS ===
  // Note: Basic vim motions and commands are handled by Zed's built-in vim mode
  // This keymap focuses on leader key sequences and special mappings

  {
    "context": "VimControl && !menu",
    "bindings": {
      // === NAVIGATION SHORTCUTS ===
      // Go to definition (gd in vim config)
      "g d": "editor::GoToDefinition",
      "g D": "editor::GoToDefinitionSplit",
      "g y": "editor::GoToTypeDefinition",
      "g i": "editor::GoToImplementation",
      "g I": "editor::GoToImplementationSplit",
      "g r": "editor::FindAllReferences",
      "g h": "editor::Hover",
      "g x": "editor::ToggleCodeActions",

      // === BACK NAVIGATION ===
      "ctrl-t": "pane::GoBack",
      "ctrl-o": "pane::GoBack"
    }
  },

  // === LEADER KEY SEQUENCES ===
  // Zed handles vim leader sequences through vim mode, but we can add custom bindings
  {
    "context": "VimControl && !menu",
    "bindings": {
      // === FILE OPERATIONS (leader+f) ===
      "space f f": "file_finder::Toggle",
      "space f r": "recent_projects::OpenRecent",
      "space f g": "project_search::ToggleFocus",
      "space f s": "workspace::Save",
      "space f S": "workspace::SaveAll",
      "space f n": "workspace::NewFile",
      "space f o": "project_panel::ToggleFocus",
      "space f t": "project_panel::ToggleFocus",
      "space f e": "project_panel::ToggleFocus",
      "space f w": "workspace::Save",

      // === BUFFER OPERATIONS (leader+b) ===
      "space b b": "tab_switcher::Toggle",
      "space b d": "pane::CloseActiveItem",
      "space b n": "pane::ActivateNextItem",
      "space b p": "pane::ActivatePrevItem",
      "space b o": "pane::CloseInactiveItems",
      "space b a": "pane::CloseAllItems",
      "space b r": "pane::ReopenClosedItem",

      // === WINDOW MANAGEMENT (leader+w) ===
      "space w h": "workspace::ActivatePaneInDirection(Left)",
      "space w l": "workspace::ActivatePaneInDirection(Right)",
      "space w j": "workspace::ActivatePaneInDirection(Down)",
      "space w k": "workspace::ActivatePaneInDirection(Up)",
      "space w v": "pane::SplitRight",
      "space w s": "pane::SplitDown",
      "space w d": "pane::CloseAllItems",

      // === CODE ACTIONS (leader+c) ===
      "space c a": "editor::ToggleCodeActions",
      "space c r": "editor::Rename",
      "space c f": "editor::Format",
      "space c d": "editor::Hover",
      "space c i": "editor::GoToImplementation",
      "space c o": "editor::ToggleCodeActions",
      "space c s": "outline::Toggle",
      "space c x": "editor::ToggleCodeActions",
      "space c l": "editor::ToggleCodeActions",

      // === GIT OPERATIONS (leader+g) ===
      "space g g": "project_panel::ToggleFocus",
      "space g s": "editor::ToggleHunkDiff",
      "space g b": "editor::ToggleGitBlame",
      "space g h s": "editor::ToggleHunkDiff",
      "space g h p": "editor::ToggleHunkDiff",
      "space g h r": "editor::RevertSelectedHunks",
      "space g l": "editor::ToggleGitBlame",
      "space g d": "editor::ToggleHunkDiff",

      // === QUICK ACCESS ===
      "space e": "project_panel::ToggleFocus",
      "space t": "terminal_panel::ToggleFocus",

      // === ADDITIONAL LAZYVIM-STYLE BINDINGS ===
      "space s f": "file_finder::Toggle",
      "space s g": "project_search::ToggleFocus",
      "space s s": "outline::Toggle",
      "space s w": "project_search::ToggleFocus",
      "space u": "editor::ToggleGitBlame",
      "space x": "editor::ToggleCodeActions",
      "space q": "pane::CloseActiveItem",
      "space .": "file_finder::Toggle",

      // === LAZYVIM SHORTCUTS ===
      "space space": "file_finder::Toggle",
      "space ,": "tab_switcher::Toggle",
      "space /": "buffer_search::Deploy"
    }
  },

  // === CUSTOM ARROW KEY MAPPINGS (matching Neovim) ===
  // Maps arrow keys to window navigation like Neovim: <Down> -> <C-w>j, etc.
  {
    "context": "Editor && vim_mode == normal",
    "bindings": {
      "down": "workspace::ActivatePaneInDirection(Down)",
      "up": "workspace::ActivatePaneInDirection(Up)",
      "right": "workspace::ActivatePaneInDirection(Right)",
      "left": "workspace::ActivatePaneInDirection(Left)"
    }
  },

  // === GENERAL EDITOR KEYBINDINGS ===
  {
    "context": "Editor",
    "bindings": {
      // === COMMON VS CODE/CURSOR SHORTCUTS ===
      "cmd-p": "file_finder::Toggle",
      "cmd-shift-p": "command_palette::Toggle",
      "cmd-shift-f": "project_search::ToggleFocus",
      "cmd-`": "terminal_panel::ToggleFocus",
      "cmd-shift-e": "project_panel::ToggleFocus",
      "cmd-b": "project_panel::ToggleFocus",

      // === EDITOR ACTIONS ===
      "cmd-shift-k": "editor::DeleteLine",
      "alt-up": "editor::MoveLineUp",
      "alt-down": "editor::MoveLineDown",
      "alt-shift-down": "editor::DuplicateLineDown",
      "alt-shift-up": "editor::DuplicateLineUp",
      "cmd-/": "editor::ToggleComments",

      // === NAVIGATION ===
      "cmd-t": "pane::GoBack",
      "f12": "editor::GoToDefinition",
      "shift-f12": "editor::FindAllReferences",
      "cmd-f12": "editor::GoToImplementation",

      // === FORMATTING ===
      "shift-alt-f": "editor::Format",
      "cmd-k cmd-f": "editor::Format",

      // === SEARCH ===
      "cmd-f": "buffer_search::Deploy",
      "cmd-g": "search::SelectNextMatch",
      "cmd-shift-g": "search::SelectPrevMatch",
      "cmd-shift-h": "project_search::ToggleReplace",

      // === QUICK FIXES ===
      "cmd-.": "editor::ToggleCodeActions"
    }
  },

  // === PROJECT PANEL BINDINGS ===
  {
    "context": "ProjectPanel",
    "bindings": {
      "space": "project_panel::Open",
      "enter": "project_panel::Open",
      "o": "project_panel::Open",
      "h": "project_panel::CollapseSelectedEntry",
      "l": "project_panel::ExpandSelectedEntry",
      "a": "project_panel::NewFile",
      "A": "project_panel::NewDirectory",
      "r": "project_panel::Rename",
      "d": "project_panel::Delete",
      "x": "project_panel::Cut",
      "c": "project_panel::Copy",
      "p": "project_panel::Paste"
    }
  },

  // === TERMINAL BINDINGS ===
  {
    "context": "Terminal",
    "bindings": {
      "cmd-`": "terminal_panel::ToggleFocus",
      "ctrl-shift-`": "terminal_panel::ToggleFocus",
      "cmd-t": "terminal_panel::ToggleFocus"
    }
  },

  // === SEARCH PANEL BINDINGS ===
  {
    "context": "ProjectSearchBar",
    "bindings": {
      "escape": "project_search::ToggleFocus",
      "cmd-shift-f": "project_search::ToggleFocus"
    }
  },

  // === VIM INSERT MODE OVERRIDES ===
  {
    "context": "VimControl && VimInsert",
    "bindings": {
      // Allow some common shortcuts in insert mode
      "cmd-a": "editor::SelectAll",
      "cmd-c": "editor::Copy",
      "cmd-v": "editor::Paste",
      "cmd-x": "editor::Cut",
      "cmd-z": "editor::Undo",
      "cmd-shift-z": "editor::Redo"
    }
  },

  // === VISUAL MODE BINDINGS ===
  {
    "context": "VimControl && VimVisual",
    "bindings": {
      // Format selection (matches VS Code vim config)
      "space c f": "editor::Format"
    }
  },

  // === GLOBAL SHORTCUTS (work in any context) ===
  {
    "context": "Workspace",
    "bindings": {
      "cmd-k cmd-t": "theme_selector::Toggle",
      "cmd-k cmd-s": "zed::OpenKeymap",
      "cmd-k cmd-,": "zed::OpenSettings",
      "cmd-shift-n": "workspace::NewWindow",
      "cmd-shift-w": "workspace::CloseWindow",
      "cmd-w": "pane::CloseActiveItem",
      "cmd-shift-t": "pane::ReopenClosedItem",
      "cmd-1": "pane::ActivateItem(0)",
      "cmd-2": "pane::ActivateItem(1)",
      "cmd-3": "pane::ActivateItem(2)",
      "cmd-4": "pane::ActivateItem(3)",
      "cmd-5": "pane::ActivateItem(4)",
      "cmd-6": "pane::ActivateItem(5)",
      "cmd-7": "pane::ActivateItem(6)",
      "cmd-8": "pane::ActivateItem(7)",
      "cmd-9": "pane::ActivateItem(8)"
    }
  }
]
