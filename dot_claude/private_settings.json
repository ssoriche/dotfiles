{
  "env": {},
  "includeCoAuthoredBy": false,
  "permissions": {
    "allow": [],
    "deny": [],
    "ask": []
  },
  "model": "opus[1m]",
  "hooks": {},
  "statusLine": {
    "type": "command",
    "command": "bunx -y ccstatusline@latest",
