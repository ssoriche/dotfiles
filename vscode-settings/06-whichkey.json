{
  // Which Key Core Settings
  "whichkey.sortOrder": "alphabetically",
  "whichkey.delay": 0,

  // Which Key Menu Bindings
  "whichkey.bindings": [
    // Surround Operations
    {
      "key": "c s",
      "name": "Change surroundings",
      "type": "command",
      "command": "vim.remap",
      "args": {
        "after": ["c", "s"]
      }
    },
    {
      "key": "d s",
      "name": "Delete surroundings",
      "type": "command",
      "command": "vim.remap",
      "args": {
        "after": ["d", "s"]
      }
    },
    {
      "key": "y s",
      "name": "Add surroundings",
      "type": "command",
      "command": "vim.remap",
      "args": {
        "after": ["y", "s"]
      }
    },

    // Navigation and Code Intelligence
    {
      "key": "g",
      "name": "+goto",
      "type": "bindings",
      "bindings": [
        {
          "key": "d",
          "name": "Go to Definition",
          "type": "command",
          "command": "editor.action.revealDefinition"
        },
        {
          "key": "D",
          "name": "Peek Definition",
          "type": "command",
          "command": "editor.action.peekDefinition"
        },
        {
          "key": "y",
          "name": "Go to Type Definition",
          "type": "command",
          "command": "editor.action.goToTypeDefinition"
        },
        {
          "key": "i",
          "name": "Go to Implementation",
          "type": "command",
          "command": "editor.action.goToImplementation"
        },
        {
          "key": "I",
          "name": "Peek Implementation",
          "type": "command",
          "command": "editor.action.peekImplementation"
        },
        {
          "key": "r",
          "name": "Go to References",
          "type": "command",
          "command": "editor.action.goToReferences"
        },
        {
          "key": "h",
          "name": "Show Hover",
          "type": "command",
          "command": "editor.action.showHover"
        },
        {
          "key": "x",
          "name": "Quick Fix",
          "type": "command",
          "command": "editor.action.quickFix"
        }
      ]
    },

    // File Operations Menu
    {
      "key": "f",
      "name": "+file",
      "type": "bindings",
      "bindings": [
        {
          "key": "f",
          "name": "Find File",
          "type": "command",
          "command": "workbench.action.quickOpen"
        },
        {
          "key": "r",
          "name": "Recent Files",
          "type": "command",
          "command": "workbench.action.openRecent"
        },
        {
          "key": "g",
          "name": "Find in Files",
          "type": "command",
          "command": "workbench.action.findInFiles"
        },
        {
          "key": "s",
          "name": "Save File",
          "type": "command",
          "command": "workbench.action.files.save"
        },
        {
          "key": "S",
          "name": "Save All Files",
          "type": "command",
          "command": "workbench.action.files.saveAll"
        }
      ]
    },

    // Buffer Operations Menu
    {
      "key": "b",
      "name": "+buffer",
      "type": "bindings",
      "bindings": [
        {
          "key": "b",
          "name": "Show All Buffers",
          "type": "command",
          "command": "workbench.action.showAllEditors"
        },
        {
          "key": "d",
          "name": "Delete Buffer",
          "type": "command",
          "command": "workbench.action.closeActiveEditor"
        },
        {
          "key": "n",
          "name": "Next Buffer",
          "type": "command",
          "command": "workbench.action.nextEditor"
        },
        {
          "key": "p",
          "name": "Previous Buffer",
          "type": "command",
          "command": "workbench.action.previousEditor"
        }
      ]
    },

    // Quick Access Commands
    {
      "key": "e",
      "name": "Explorer",
      "type": "command",
      "command": "workbench.view.explorer"
    },
    {
      "key": "t",
      "name": "Toggle Terminal",
      "type": "command",
      "command": "workbench.action.terminal.toggleTerminal"
    },

    // Git Operations Menu
    {
      "key": "g",
      "name": "+git",
      "type": "bindings",
      "bindings": [
        {
          "key": "g",
          "name": "Source Control",
          "type": "command",
          "command": "workbench.view.scm"
        },
        {
          "key": "s",
          "name": "Stage Changes",
          "type": "command",
          "command": "git.stage"
        },
        {
          "key": "u",
          "name": "Unstage Changes",
          "type": "command",
          "command": "git.unstage"
        }
      ]
    },

    // Code Actions Menu
    {
      "key": "c",
      "name": "+code",
      "type": "bindings",
      "bindings": [
        {
          "key": "a",
          "name": "Quick Fix",
          "type": "command",
          "command": "editor.action.quickFix"
        },
        {
          "key": "r",
          "name": "Rename Symbol",
          "type": "command",
          "command": "editor.action.rename"
        },
        {
          "key": "f",
          "name": "Format Document",
          "type": "command",
          "command": "editor.action.formatDocument"
        },
        {
          "key": "d",
          "name": "Go to Definition",
          "type": "command",
          "command": "editor.action.revealDefinition"
        },
        {
          "key": "i",
          "name": "Go to Implementation",
          "type": "command",
          "command": "editor.action.goToImplementation"
        }
      ]
    },

    // Window Management Menu
    {
      "key": "w",
      "name": "+window",
      "type": "bindings",
      "bindings": [
        {
          "key": "h",
          "name": "Focus Left",
          "type": "command",
          "command": "workbench.action.focusLeftGroup"
        },
        {
          "key": "l",
          "name": "Focus Right",
          "type": "command",
          "command": "workbench.action.focusRightGroup"
        },
        {
          "key": "j",
          "name": "Focus Down",
          "type": "command",
          "command": "workbench.action.focusBelowGroup"
        },
        {
          "key": "k",
          "name": "Focus Up",
          "type": "command",
          "command": "workbench.action.focusAboveGroup"
        },
        {
          "key": "v",
          "name": "Split Vertical",
          "type": "command",
          "command": "workbench.action.splitEditor"
        },
        {
          "key": "s",
          "name": "Split Horizontal",
          "type": "command",
          "command": "workbench.action.splitEditorDown"
        },
        {
          "key": "d",
          "name": "Close Window",
          "type": "command",
          "command": "workbench.action.closeEditorsInGroup"
        }
      ]
    }
  ],

  // Vim Integration
  "vim.normalModeKeyBindingsNonRecursive": [
    {
      "before": ["<space>"],
      "commands": ["whichkey.show"]
    }
  ]
}
