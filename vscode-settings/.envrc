#!/usr/bin/env bash

# Source VSCode management aliases if using fish shell
if [ -n "$FISH_VERSION" ]; then
    source "$PWD/bin/vscode-manager-aliases.fish"
fi

# Add bin directory to PATH
export PATH="$PWD/bin:$PATH"

# Environment variables for the VSCode settings project
export VSCODE_SETTINGS_DIR="$PWD"
export CHEZMOI_SOURCE_DIR="$(chezmoi source-path 2>/dev/null || echo "$HOME/.local/share/chezmoi")"

# Optional: Set up development environment
export EDITOR="${EDITOR:-cursor}"
