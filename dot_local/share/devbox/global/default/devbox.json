  "shell": {
    "init_hook": [
      "export PATH=\"$HOME/.local/bin:$PATH\"",
      "bash \"$HOME/.local/bin/sync-devbox-apps.sh\" 2>/dev/null || true"
    ],
    "scripts": {
      "setup-tools": [
        "uv tool install --force --python python3.14 llm@latest",
        "uv tool install --force --python python3.14 aider@latest",
        "uv tool install --force --python python3.14 claude-code-transcripts"
      ],
      "update-tools": [
        "uv tool upgrade --all"
      ],
      "link-apps": [
        "for app in ~/.local/share/devbox/global/default/.devbox/nix/profile/default/Applications/*.app; do",
        "  app_name=$(basename \"$app\")",
        "  resolved_path=$(readlink -f \"$app\")",
        "  echo \"Processing: $app_name\"",
        "  echo \"  Resolved path: $resolved_path\"",
        "  if [ -e \"/Applications/$app_name\" ] || [ -L \"/Applications/$app_name\" ]; then",
        "    echo \"  Removing existing: /Applications/$app_name\"",
        "    rm -rf \"/Applications/$app_name\"",
        "  fi",
        "  echo \"  Creating alias...\"",
        "  osascript -e \"tell application \\\"Finder\\\" to make alias file to POSIX file \\\"$resolved_path\\\" at POSIX file \\\"/Applications\\\"\" || echo \"  ERROR: Failed to create alias\"",
        "done",
        "echo 'Done. Checking results:'",
        "ls -la /Applications/*.app 2>/dev/null | grep -E 'Aero|Wez|Halloy|Maccy|Obsidian' || echo 'No matching apps found'"
      ]
    }
  }
}
